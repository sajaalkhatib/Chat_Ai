@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - SK.AI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }
        .auth-container {
            width: 100%;
            max-width: 420px;
            padding: 2.5rem;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        .brand {
            color: #d97757;
            font-weight: 800;
            font-size: 2.2rem;
            text-align: center;
            margin-bottom: 0.5rem;
            letter-spacing: 1px;
        }
        .subtitle {
            text-align: center;
            color: #6c757d;
            margin-bottom: 2rem;
            font-size: 1.1rem;
        }
        .form-control {
            border-radius: 10px;
            padding: 0.8rem 1.2rem;
            border: 1px solid #e0e0e0;
            background-color: #fafafa;
            transition: all 0.3s;
        }
        .form-control:focus {
            border-color: #d97757;
            box-shadow: 0 0 0 0.25rem rgba(217, 119, 87, 0.15);
            background-color: #ffffff;
        }
        .form-label {
            color: #495057;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
        .btn-primary {
            background-color: #d97757;
            border-color: #d97757;
            border-radius: 10px;
            padding: 0.8rem;
            font-weight: 600;
            font-size: 1.05rem;
            width: 100%;
            margin-top: 1.5rem;
            transition: all 0.3s;
        }
        .btn-primary:hover {
            background-color: #c46345;
            border-color: #c46345;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(217, 119, 87, 0.2);
        }
        .btn-google {
            background-color: #ffffff;
            border: 1px solid #e0e0e0;
            color: #333;
            border-radius: 10px;
            padding: 0.8rem;
            font-weight: 600;
            width: 100%;
            margin-top: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.3s;
        }
        .btn-google:hover {
            background-color: #f8f9fa;
            border-color: #d2d2d2;
            transform: translateY(-1px);
        }
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 1.8rem 0;
            color: #adb5bd;
            font-size: 0.9rem;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e0e0e0;
        }
        .divider:not(:empty)::before {
            margin-left: 1rem;
        }
        .divider:not(:empty)::after {
            margin-right: 1rem;
        }
        .footer-links {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.95rem;
        }
        .footer-links a {
            color: #d97757;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }
        .footer-links a:hover {
            color: #c46345;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="brand"><i class="bi bi-robot"></i> SK.AI</div>
        <div class="subtitle">مرحباً بك مجدداً</div>

        <form method="post" action="/Account/Login">
            <div class="mb-3 text-end">
                <label class="form-label">البريد الإلكتروني</label>
                <input type="email" class="form-control text-end" name="email" placeholder="name@example.com" required>
            </div>
            <div class="mb-3 text-end">
                <label class="form-label">كلمة المرور</label>
                <input type="password" class="form-control text-end" name="password" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-primary">تسجيل الدخول</button>
        </form>

        <div class="divider">أو</div>

        <a href="/Account/ExternalLogin?provider=Google" class="btn btn-google text-decoration-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            المتابعة باستخدام Google
        </a>

        <div class="footer-links">
            <span class="text-muted">ليس لديك حساب؟</span> <a href="/Account/Register">إنشاء حساب جديد</a>
        </div>
    </div>
</body>
</html>
