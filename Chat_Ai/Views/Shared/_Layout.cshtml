<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chat_Ai</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Chat_Ai.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/Layout.css" asp-append-version="true" />

</head>
<body>
    <!-- Global Loader -->
    <div id="page-loader">
        <div class="loader-icon">
            <i class="bi bi-robot"></i>
        </div>
        <div class="loader-text">Loading SK.AI...</div>
    </div>

    <div class="wrapper">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <button class="new-chat-btn" onclick="startNewChat()">
                    <i class="bi bi-chat-square-text"></i> New chat
                </button>
            </div>
            <div class="sidebar-body px-2 overflow-auto flex-grow-1">
                <div class="px-3 mb-2">
                    <small class="text-muted" style="font-size: 0.75rem; font-weight: 600;">Recent</small>
                </div>
                <!-- Dynamic history items loaded by JS -->
                <div id="chatHistoryList">
                    <div class="text-muted px-3 py-2" style="font-size: 0.8rem;">Loading...</div>
                </div>
            </div>
            <div class="sidebar-footer p-3 border-top">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-person-circle fs-4 me-2 text-secondary"></i>
                            <span class="text-dark fw-medium">@User.Identity.Name</span>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-sm btn-outline-secondary border-0" title="تسجيل الخروج">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="d-flex align-items-center text-decoration-none" style="cursor: pointer;">
                        <i class="bi bi-person-circle fs-4 me-2 text-secondary"></i>
                        <span class="text-dark fw-medium">تسجيل الدخول</span>
                    </a>
                }
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Navbar -->
            <nav class="navbar navbar-custom d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold" style="color: #d97757;">SK.AI</h5>
              
            </nav>

            <!-- Body -->
            <div class="content-body">
                @RenderBody()
            </div>

            <!-- Footer -->
            <footer class="footer-custom">
                &copy; 2026 - SK.AI - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-secondary">Privacy</a>. AI can make mistakes. Consider verifying important information.
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
	<script src="~/js/Layout.js" asp-append-version="true"></script>    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
